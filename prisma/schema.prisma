// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- NextAuth Core Models ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  ADVISOR
  FINANCE_MANAGER
  VIEWER
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 Role      @default(VIEWER)
  plan                 Plan      @default(FREE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?
  onboardingCompleted  Boolean   @default(false)
  accounts             Account[]
  sessions             Session[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Domain Models ---
model Client {
  id          String    @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  status      String    @default("ACTIVE")
  entities    Entity[]
  invoices    Invoice[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Entity {
  id           String        @id @default(cuid())
  clientId     String?
  name         String
  type         String
  country      String
  currency     String        @default("USD")
  taxId        String?
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bankAccounts BankAccount[]
  invoices     Invoice[]
  taxProfile   TaxProfile?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model BankConnection {
  id            String        @id @default(cuid())
  provider      String
  institution   String
  institutionId String?
  requisitionId String?       @unique
  externalId    String?
  accessToken   String?
  refreshToken  String?
  status        String        @default("ACTIVE")
  lastSync      DateTime?
  accounts      BankAccount[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model BankAccount {
  id               String          @id @default(cuid())
  entityId         String
  bankConnectionId String?
  name             String
  accountType      String
  currency         String          @default("USD")
  balance          Float           @default(0)
  accountNumber    String?
  iban             String?
  externalId       String?         @unique
  entity           Entity          @relation(fields: [entityId], references: [id], onDelete: Cascade)
  connection       BankConnection? @relation(fields: [bankConnectionId], references: [id], onDelete: SetNull)
  transactions     Transaction[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Transaction {
  id             String        @id @default(cuid())
  accountId      String
  date           DateTime
  amount         Float
  currency       String
  description    String
  category       String?
  status         String        @default("COMPLETED")
  notes          String?
  taxRelevant    Boolean       @default(false)
  isSubscription Boolean       @default(false)
  externalId     String?
  account        BankAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  subscriptionId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([accountId, externalId])
}

model Subscription {
  id              String        @id @default(cuid())
  name            String
  merchant        String
  interval        String
  amount          Float
  currency        String
  status          String        @default("ACTIVE")
  wasteDetected   Boolean       @default(false)
  nextBillingDate DateTime?
  transactions    Transaction[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Invoice {
  id        String        @id @default(cuid())
  entityId  String
  clientId  String
  number    String        @unique
  date      DateTime
  dueDate   DateTime
  status    String        @default("DRAFT")
  currency  String        @default("USD")
  notes     String?
  entity    Entity        @relation(fields: [entityId], references: [id], onDelete: Cascade)
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lines     InvoiceLine[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  amount      Float
  taxRate     Float   @default(0)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model TaxProfile {
  id               String        @id @default(cuid())
  entityId         String        @unique
  fiscalYearStart  DateTime?
  fiscalYearEnd    DateTime?
  vatNumber        String?
  corporateTaxRate Float?
  entity           Entity        @relation(fields: [entityId], references: [id], onDelete: Cascade)
  deadlines        TaxDeadline[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model TaxDeadline {
  id           String     @id @default(cuid())
  taxProfileId String
  title        String
  description  String?
  date         DateTime
  type         String
  status       String     @default("PENDING")
  taxProfile   TaxProfile @relation(fields: [taxProfileId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Alert {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}
